# ===========================================
# PadelPlay - Variables de Entorno
# ===========================================
# Copiar este archivo a '.env' y completar los valores

# ===========================================
# GOOGLE OAUTH 2.0
# ===========================================
# Obtener en: https://console.cloud.google.com/apis/credentials
# 1. Crear proyecto o seleccionar existente
# 2. Configurar "OAuth consent screen" (External o Internal)
# 3. Crear "OAuth 2.0 Client IDs" -> Web application
# 4. Añadir orígenes autorizados: http://localhost:8080, http://localhost:8081
# 5. Copiar el Client ID aquí

GOOGLE_CLIENT_ID=""tu-client-id.apps.googleusercontent.com""

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Secret key para firmar tokens (mínimo 256 bits / 32 caracteres)
# Generar con: openssl rand -base64 32

JWT_SECRET=""padelplay-super-secret-key-cambiar-en-produccion-minimo-32-caracteres""

# Tiempo de expiración del token en milisegundos (default: 24 horas)
JWT_EXPIRATION=86400000

# ===========================================
# DATABASE (cuando se use MySQL en producción)
# ===========================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=padelplaydb
# DB_USER=padelplay_user
# DB_PASSWORD=tu-password-seguro

# ===========================================
# PadelPlay - Credenciales locales
# ===========================================
# Rellena estos valores para enviar recordatorios con Gmail real.

# SMTP Gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=joneritz.pascual@opendeusto.es
MAIL_PASSWORD=opkp cezc fojx kmhl
MAIL_FROM=joneritz.pascual@opendeusto.es
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000

# Recordatorios (cada cuanto revisa pendientes, en milisegundos)
REMINDER_POLL_DELAY_MS=15000

# OAuth/JWT (opcionales aqui, solo si los necesitas para tu login local)
GOOGLE_CLIENT_ID=
JWT_SECRET=
JWT_EXPIRATION=86400000